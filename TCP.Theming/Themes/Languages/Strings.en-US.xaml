<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Navbar -->
    <system:String x:Key="String.Home">Home</system:String>
    <system:String x:Key="String.Electronics">Electronics</system:String>
    <system:String x:Key="String.Editor">Editor</system:String>
    <system:String x:Key="String.Search">Search...</system:String>

    <!-- Settings -->
    <system:String x:Key="String.Settings">Settings</system:String>
    <system:String x:Key="String.Theme">Theme</system:String>
    <system:String x:Key="String.Theme.Dark">Dark</system:String>
    <system:String x:Key="String.Theme.Light">Light</system:String>
    <system:String x:Key="String.Language">Language</system:String>
    <system:String x:Key="String.Appearance">Appearance</system:String>
    <system:String x:Key="String.Application">Application</system:String>

    <!-- Canvas -->
    <system:String x:Key="String.LoadImage">Load Image</system:String>
    <system:String x:Key="String.LockImage">Lock</system:String>
    <system:String x:Key="String.UnlockImage">Unlock</system:String>

    <!-- General -->
    <system:String x:Key="String.Save">Save</system:String>
    <system:String x:Key="String.Cancel">Cancel</system:String>

</ResourceDictionary>
