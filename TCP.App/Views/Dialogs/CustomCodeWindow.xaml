<Window x:Class="TCP.App.Views.Dialogs.CustomCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Kod Yaz" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Surface}"
        Foreground="{DynamicResource Brush.Text.Primary}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock" Text="Kod Yaz" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <TextBox x:Name="CodeTextBox" Grid.Row="1" Margin="0,0,0,16" 
                 AcceptsReturn="True" AcceptsTab="True" 
                 FontFamily="Consolas" FontSize="14" 
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Content="İptal" Appearance="Secondary" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <ui:Button Content="Kaydet" Appearance="Primary" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
