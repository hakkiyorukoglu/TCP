<Window x:Class="TCP.App.Views.Dialogs.OtaUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="OTA Yazılım Yükleme" Height="420" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Background.Primary}"
        Foreground="{DynamicResource Brush.Text.Primary}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="🚀" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <TextBlock Text="OTA Firmware Güncelleme" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>
        
        <!-- Target Info -->
        <Border Grid.Row="1" Background="{DynamicResource Brush.Background.Secondary}" CornerRadius="6" Padding="15" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Hedef İstasyon:" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,15,0" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="StationNameText" Text="İstasyon 1" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="IpAddressText" Text="http://192.168.1.10" Foreground="{DynamicResource Brush.Palette.Blue}" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- File Selection -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Firmware Dosyası (.bin):" Margin="0,0,0,8" FontWeight="SemiBold"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:TextBox x:Name="FilePathTextBox" IsReadOnly="True" Margin="0,0,10,0" PlaceholderText="Lütfen bir .bin dosyası seçin..."/>
                <ui:Button Grid.Column="1" Content="Gözat..." Appearance="Secondary" Click="Browse_Click"/>
            </Grid>
            
            <TextBlock Text="Ağ üzerinden HTTP POST multipart form verisi ile gönderilir. İşlem cihazın bağlantı hızına göre 10-30 saniye sürebilir." 
                       TextWrapping="Wrap" Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="12"/>
        </StackPanel>

        <!-- Progress Area -->
        <StackPanel Grid.Row="3" Margin="0,0,0,20">
            <TextBlock x:Name="StatusText" Text="Hazır." Margin="0,0,0,8" FontWeight="SemiBold"/>
            <ProgressBar x:Name="UploadProgress" Height="20" Minimum="0" Maximum="100" Value="0" />
        </StackPanel>

        <!-- Action Buttons -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="0" Content="İptal" Appearance="Secondary" HorizontalAlignment="Left" Click="Close_Click" Width="100"/>
            <ui:Button x:Name="UploadButton" Grid.Column="1" Content="Yüklemeyi Başlat" Appearance="Primary" Click="Upload_Click" Width="160" IsEnabled="False">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="ArrowUpload24"/>
                </ui:Button.Icon>
            </ui:Button>
        </Grid>
    </Grid>
</Window>
