<Window x:Class="TCP.App.Views.Dialogs.RelayControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Canlı Röle Kontrol" Height="380" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Background.Primary}"
        Foreground="{DynamicResource Brush.Text.Primary}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Röle / Pin Kontrol" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
        
        <Border Grid.Row="1" Background="{DynamicResource Brush.Background.Secondary}" CornerRadius="6" Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Seçili İstasyon:" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,5"/>
                <TextBlock x:Name="StationNameText" Text="İstasyon 1" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="IP: " Foreground="{DynamicResource Brush.Text.Secondary}"/>
                    <TextBlock x:Name="IpAddressText" Text="192.168.1.10" Foreground="{DynamicResource Brush.Palette.Blue}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Control Area -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Hedef Pin:" Margin="0,0,0,5" Foreground="{DynamicResource Brush.Text.Secondary}"/>
            <ComboBox x:Name="PinComboBox" Margin="0,0,0,20" Width="200" HorizontalAlignment="Left" DisplayMemberPath="DisplayName" SelectedValuePath="Pin"/>

            <TextBlock Text="Yeni Durum (State):" Margin="0,0,0,5" Foreground="{DynamicResource Brush.Text.Secondary}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <RadioButton x:Name="RadioOn" Content="AÇIK (1)" IsChecked="True" Margin="0,0,15,0"/>
                <RadioButton x:Name="RadioOff" Content="KAPALI (0)"/>
            </StackPanel>
        </StackPanel>

        <!-- Action Buttons -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="0" Content="Kapat" Appearance="Secondary" HorizontalAlignment="Left" Click="Close_Click" Width="100"/>
            <ui:Button Grid.Column="1" Content="Gönder (HTTP GET)" Appearance="Primary" Click="Send_Click" Width="160">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="Send24"/>
                </ui:Button.Icon>
            </ui:Button>
        </Grid>
    </Grid>
</Window>
