<UserControl x:Class="TCP.App.Views.Components.TerminalPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:viewmodels="clr-namespace:TCP.App.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="150" d:DesignWidth="800"
             BorderBrush="{DynamicResource Brush.Border}"
             BorderThickness="0,1,0,0"
             Background="{DynamicResource Brush.Surface.Secondary}">
             
    <UserControl.DataContext>
        <viewmodels:TerminalViewModel/>
    </UserControl.DataContext>
    
    <UserControl.Resources>
        <Style x:Key="TerminalScrollStyle" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Visible"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsVisible}" Value="False">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.RowDefinitions>
            <!-- Header with Title and Buttons -->
            <RowDefinition Height="28"/>
            <!-- Content Area (Messages + Input) -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Grid.Row="0" Background="{DynamicResource Brush.Surface}">
            <TextBlock Text="TERMINAL" 
                       VerticalAlignment="Center" 
                       Margin="10,0,0,0" 
                       FontSize="11" 
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.Text.Secondary}" 
                       FontFamily="Consolas, Courier New"/>
                       
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0">
                <Button Content="_" Width="24" Height="22" Padding="0,-5,0,0" FontSize="10" Margin="2,0" 
                        Click="BtnMinimize_Click" Background="Transparent" BorderThickness="0" 
                        Foreground="{DynamicResource Brush.Text.Secondary}" ToolTip="Minimize"/>
                <Button Content="☐" Width="24" Height="22" FontSize="10" Margin="2,0" 
                        Click="BtnNormal_Click" Background="Transparent" BorderThickness="0" 
                        Foreground="{DynamicResource Brush.Text.Secondary}" ToolTip="Normal"/>
                <Button Content="O" Width="24" Height="22" FontSize="10" Margin="2,0" 
                        Click="BtnExpand_Click" Background="Transparent" BorderThickness="0" 
                        Foreground="{DynamicResource Brush.Text.Secondary}" ToolTip="Expand"/>
            </StackPanel>
        </Grid>
        
        <!-- Main Terminal Content, hidden if minimized -->
        <Grid Grid.Row="1" x:Name="ContentGrid" Margin="0" Background="#1E1E1E">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Output List -->
            <ListView x:Name="TerminalOutput"
                      Grid.Row="0"
                      ItemsSource="{Binding Messages}"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="LightGray"
                      FontFamily="Consolas, Courier New"
                      FontSize="12"
                      Margin="5,5,5,0"
                      ScrollViewer.CanContentScroll="False">
                <ListView.Style>
                    <Style TargetType="ListView">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMinimized}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Style>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,1">
                            <TextBlock Text="{Binding FormattedTime}" Foreground="DarkGray" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding Message}" Foreground="{Binding Color}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
            
            <!-- Input Area -->
            <Grid Grid.Row="1" Margin="5,0,5,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                           Text="TCP&gt;" 
                           Foreground="Cyan" 
                           FontFamily="Consolas, Courier New" 
                           FontSize="12"
                           FontWeight="Bold"
                           VerticalAlignment="Center" 
                           Margin="0,0,5,0"/>
                           
                <TextBox x:Name="CommandInput" 
                         Grid.Column="1" 
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent" 
                         BorderThickness="0" 
                         Foreground="WhiteSmoke"
                         FontFamily="Consolas, Courier New"
                         FontSize="12"
                         CaretBrush="White"
                         Padding="0,2"
                         PreviewKeyDown="CommandInput_PreviewKeyDown"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
