<UserControl x:Class="TCP.App.Views.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:TCP.App"
             xmlns:viewmodels="clr-namespace:TCP.App.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="Transparent">
    <!--
        EditorView.xaml - Editor view
        
        TCP-1.0.2: Background Image Load (Editor)
        Bu view editor içeriğini gösterir.
        MVVM Pattern: Sadece UI, hiçbir mantık içermez.
        
        Layout:
        - Editor toolbar (under TopBar)
        - Main editor area with background image display
    -->
    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    <UserControl.DataContext>
        <viewmodels:EditorViewModel/>
    </UserControl.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <!-- Editor Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Main Content (Palette + Editor Area) -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Editor Toolbar -->
        <!-- TCP-1.0.2: Editor-local toolbar (visible ONLY inside Editor page) -->
        <Border Grid.Row="0"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Buttons -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Status Text -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Buttons -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <!-- Load Image Button -->
                    <ui:Button Content="Add Image"
                               Command="{Binding LoadImageCommand}"
                               Appearance="Secondary"
                               Margin="0,0,8,0"
                               Cursor="Hand"/>
                    
                    <!-- Remove Selected Image Button -->
                    <ui:Button Content="Remove Image"
                               Command="{Binding RemoveImageCommand}"
                               Appearance="Danger"
                               Margin="0,0,8,0"
                               Cursor="Hand"/>
                    
                    <!-- Lock Button -->
                    <ToggleButton Content="{DynamicResource String.LockImage}"
                                  IsChecked="{Binding SelectedImage.IsLocked, Mode=TwoWay}"
                                  IsEnabled="{Binding HasSelectedImage}"
                                  Margin="0,0,16,0"
                                  Cursor="Hand"/>
                                  
                    <!-- Opacity Slider -->
                    <TextBlock Text="Opacity:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                    <Slider Minimum="0.1" Maximum="1.0" 
                            Value="{Binding SelectedImage.Opacity, Mode=TwoWay}"
                            IsEnabled="{Binding HasSelectedImage}"
                            Width="100" VerticalAlignment="Center" Margin="0,0,16,0"/>

                    <!-- Save / Load Layout -->
                    <ui:Button Content="Save Page"
                               Command="{Binding SaveLayoutCommand}"
                               Appearance="Primary"
                               Margin="0,0,8,0"
                               Cursor="Hand"/>
                    <ui:Button Content="Load Page"
                               Command="{Binding LoadLayoutCommand}"
                               Appearance="Secondary"
                               Margin="0,0,8,0"
                               Cursor="Hand"/>
                </StackPanel>
                
                <!-- Status Text -->
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText, Mode=OneWay, FallbackValue='No image loaded'}"
                           FontSize="{DynamicResource Font.Caption}"
                           FontFamily="{DynamicResource Font.Primary}"
                           Foreground="{DynamicResource Brush.Text.Secondary}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="16,0,0,0"/>
            </Grid>
        </Border>
        
        <!-- Main Content: Palette + Editor Area -->
        <!-- TCP-1.0.3: 2-column layout (Palette left, Editor right) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left: Palette (fixed width) -->
                <ColumnDefinition Width="240"/>
                <!-- Right: Editor Area (star) -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left: Palette Panel -->
            <!-- TCP-1.0.3: Palette sourced from BoardRegistry -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,0,1,0"
                    Margin="16,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <!-- Header -->
                        <RowDefinition Height="Auto"/>
                        <!-- Board List -->
                        <RowDefinition Height="*"/>
                        <!-- Add Button -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header: Palette -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource Brush.Background.Secondary}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <TextBlock Text="Palette"
                                   FontSize="{DynamicResource Font.Heading.Small}"
                                   FontFamily="{DynamicResource Font.Primary}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text.Primary}"/>
                    </Border>
                    
                    <!-- Board List -->
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding PaletteBoards, Mode=OneWay}"
                             SelectedItem="{Binding SelectedPaletteBoard, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Margin="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Brush.Background.Primary}"
                                        BorderThickness="0"
                                        Padding="12,8"
                                        Margin="2">
                                    <StackPanel>
                                        <!-- CustomName (bold) -->
                                        <TextBlock Text="{Binding CustomName, Mode=OneWay}"
                                                   FontSize="{DynamicResource Font.Body}"
                                                   FontFamily="{DynamicResource Font.Primary}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"/>
                                        <!-- Type + Status line -->
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,4,0,0">
                                            <!-- Type badge -->
                                            <Border Background="{DynamicResource Brush.Background.Secondary}"
                                                    BorderBrush="{DynamicResource Brush.Border}"
                                                    BorderThickness="1"
                                                    CornerRadius="2"
                                                    Padding="4,2"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Type, Mode=OneWay}"
                                                           FontSize="{DynamicResource Font.Caption}"
                                                           FontFamily="{DynamicResource Font.Primary}"
                                                           Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                            </Border>
                                            <!-- Status -->
                                            <TextBlock Text="{Binding IpAddress, Mode=OneWay, StringFormat='IP: {0}'}"
                                                       FontSize="{DynamicResource Font.Caption}"
                                                       FontFamily="{DynamicResource Font.Primary}"
                                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderThickness="0"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource Brush.Border}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource Brush.Accent.Primary}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                    
                    <!-- Add to Map Button -->
                    <ui:Button Grid.Row="2"
                               Content="Add to Map"
                               Command="{Binding AddBoxCommand}"
                               Appearance="Primary"
                               HorizontalAlignment="Stretch"
                               Margin="16"
                               Cursor="Hand"/>
                </Grid>
            </Border>
            
            <!-- Right: Editor Area -->
            <!-- TCP-1.0.2: Editor area with background image display -->
            <!-- TCP-1.0.3: Canvas overlay for placed boxes -->
            <!-- TCP-1.0.4: Viewport transform integration (Zoom/Pan) -->
            <Border x:Name="ViewportContainer"
                    Grid.Column="1"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="16,0,16,16"
                    ClipToBounds="True"
                    MouseWheel="ViewportContainer_MouseWheel"
                    MouseDown="ViewportContainer_MouseDown"
                    MouseMove="ViewportContainer_MouseMove"
                    MouseUp="ViewportContainer_MouseUp">
                <Grid>
                    <!-- Viewport Canvas with Transform -->
                    <!-- TCP-1.0.4: This Canvas applies zoom/pan transform to all children -->
                    <Canvas x:Name="ViewportCanvas"
                            Background="Transparent"
                            RenderTransform="{Binding ViewportState.Transform, Mode=OneWay}"
                            RenderTransformOrigin="0.5,0.5">
                        
                        <!-- AutoCAD-style Limited Space Grid (Z-Index -1) -->
                        <Rectangle Canvas.Left="-5000" Canvas.Top="-5000" 
                                   Width="10000" Height="10000"
                                   Panel.ZIndex="-1">
                            <Rectangle.Fill>
                                <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing>
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <LineGeometry StartPoint="0,0" EndPoint="40,0"/>
                                                    <LineGeometry StartPoint="0,0" EndPoint="0,40"/>
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                            <GeometryDrawing.Pen>
                                                <!-- Faint grid line -->
                                                <Pen Brush="#33888888" Thickness="0.5"/>
                                            </GeometryDrawing.Pen>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Background Images Container (Z-Index 0) -->
                        <ItemsControl ItemsSource="{Binding EditorImages}"
                                      Panel.ZIndex="0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                    <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="{Binding Width}" Height="{Binding Height}"
                                            BorderBrush="{DynamicResource Brush.Accent.Primary}"
                                            BorderThickness="1"
                                            Opacity="{Binding Opacity}"
                                            Background="Transparent">
                                        <Border.InputBindings>
                                            <MouseBinding Gesture="LeftClick" Command="{Binding DataContext.SelectImageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Primary}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Image Source="{Binding ImageSource}"
                                                   Stretch="Uniform"
                                                   IsHitTestVisible="True"
                                                   MouseLeftButtonDown="Image_MouseLeftButtonDown"
                                                   MouseMove="Image_MouseMove"
                                                   MouseLeftButtonUp="Image_MouseLeftButtonUp" />
                                            
                                            <!-- Resizing Thumbs -->
                                            <Thumb x:Name="ThumbTL" Width="12" Height="12" Background="{DynamicResource Brush.Accent.Primary}" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="SizeNWSE" DragDelta="ThumbTL_DragDelta" Margin="-6,-6,0,0">
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                            <Thumb x:Name="ThumbTR" Width="12" Height="12" Background="{DynamicResource Brush.Accent.Primary}" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="SizeNESW" DragDelta="ThumbTR_DragDelta" Margin="0,-6,-6,0">
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                            <Thumb x:Name="ThumbBL" Width="12" Height="12" Background="{DynamicResource Brush.Accent.Primary}" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="SizeNESW" DragDelta="ThumbBL_DragDelta" Margin="-6,0,0,-6">
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                            <Thumb x:Name="ThumbBR" Width="12" Height="12" Background="{DynamicResource Brush.Accent.Primary}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" DragDelta="ThumbBR_DragDelta" Margin="0,0,-6,-6">
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Placed Boxes Overlay (Z-Index 1) -->
                        <!-- TCP-1.0.3: Boxes drawn on top of background image -->
                        <!-- TCP-1.0.4: Boxes move WITH the viewport transform -->
                        <ItemsControl ItemsSource="{Binding PlacedBoxes, Mode=OneWay}"
                                      Panel.ZIndex="1">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X, Mode=OneWay}"/>
                                    <Setter Property="Canvas.Top" Value="{Binding Y, Mode=OneWay}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Box Card -->
                                    <!-- TCP-1.0.3: Box card with DisplayName, Type, Status -->
                                    <Border Background="{DynamicResource Brush.Background.Primary}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="2"
                                            CornerRadius="4"
                                            Padding="12,8"
                                            MinWidth="150"
                                            MaxWidth="200"
                                            Cursor="SizeAll"
                                            MouseLeftButtonDown="Box_MouseLeftButtonDown"
                                            MouseMove="Box_MouseMove"
                                            MouseLeftButtonUp="Box_MouseLeftButtonUp">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding CustomName, Mode=OneWay}"
                                                           FontSize="{DynamicResource Font.Body}"
                                                           FontFamily="{DynamicResource Font.Primary}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Text.Primary}"/>
                                                <ToggleButton Grid.Column="1" 
                                                              IsChecked="{Binding IsLocked, Mode=TwoWay}"
                                                              Padding="4" Margin="4,0,0,0" Cursor="Hand" Background="Transparent" BorderThickness="0">
                                                    <TextBlock Text="🔒" FontSize="10"/>
                                                </ToggleButton>
                                            </Grid>
                                            <!-- Type + Status line -->
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,4,0,0">
                                                <!-- Type badge -->
                                                <Border Background="{DynamicResource Brush.Background.Secondary}"
                                                        BorderBrush="{DynamicResource Brush.Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="2"
                                                        Padding="4,2"
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Type, Mode=OneWay}"
                                                               FontSize="{DynamicResource Font.Caption}"
                                                               FontFamily="{DynamicResource Font.Primary}"
                                                               Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                                </Border>
                                                <!-- Status -->
                                                <TextBlock Text="{Binding IpAddress, Mode=OneWay}"
                                                           FontSize="{DynamicResource Font.Caption}"
                                                           FontFamily="{DynamicResource Font.Primary}"
                                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>
                    
                    <!-- No Image Placeholder (not affected by transform) -->
                    <!-- TCP-1.0.4: Placeholder shown when no image loaded -->
                    <TextBlock Text="Add an image or device to start."
                               FontSize="{DynamicResource Font.Body}"
                               FontFamily="{DynamicResource Font.Primary}"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

