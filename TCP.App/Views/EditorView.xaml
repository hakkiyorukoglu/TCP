<UserControl x:Class="TCP.App.Views.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:TCP.App"
             xmlns:viewmodels="clr-namespace:TCP.App.ViewModels"
             xmlns:models="clr-namespace:TCP.App.Models.Editor"
             xmlns:electronics="clr-namespace:TCP.App.Models.Electronics"
             xmlns:converters="clr-namespace:TCP.App.Converters"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="Transparent"
             Focusable="True">
    <UserControl.InputBindings>
        <KeyBinding Key="Tab" Command="{Binding ToggleOrthogonalModeCommand}" />
        <KeyBinding Key="Backspace" Command="{Binding UndoRouteNodeCommand}" />
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoRouteNodeCommand}" />
    </UserControl.InputBindings>
    <!--
        EditorView.xaml - Editor view
        
        TCP-1.0.2: Background Image Load (Editor)
        Bu view editor içeriğini gösterir.
        MVVM Pattern: Sadece UI, hiçbir mantık içermez.
        
        Layout:
        - Editor toolbar (under TopBar)
        - Main editor area with background image display
    -->
    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter"/>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        <converters:LayerTypeToIconConverter x:Key="LayerTypeToIconConverter"/>
        <converters:ConnectionPathConverter x:Key="ConnectionPathConverter"/>
        <converters:LedColorConverter x:Key="LedColorConverter"/>
        <converters:RoutePathConverter x:Key="RoutePathConverter"/>
    </UserControl.Resources>
    <UserControl.DataContext>
        <viewmodels:EditorViewModel/>
    </UserControl.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <!-- Editor Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Main Content (Palette + Editor Area) -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- CommandManager (SolidWorks Style) -->
        <TabControl Grid.Row="0" Background="{DynamicResource Brush.Surface}" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Brush.Border}" Padding="0,4,0,4" Margin="0">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
                    <Setter Property="Padding" Value="16,6"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Margin" Value="0,0,2,0"/>
                </Style>
                <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="8"/>
                    <Setter Property="Margin" Value="2,0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Style>
                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                    <Setter Property="Appearance" Value="Transparent"/>
                    <Setter Property="Padding" Value="8"/>
                    <Setter Property="Margin" Value="2,0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Style>
            </TabControl.Resources>
            
            <TabItem Header="Çizim (Sketch)">
                <StackPanel Orientation="Horizontal" Margin="8,4">
                    <ToggleButton IsChecked="{Binding IsSelectionMode, Mode=TwoWay}" ToolTip="Seçim Aracı">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Cursor24" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <ui:SymbolIcon.Style>
                                    <Style TargetType="ui:SymbolIcon">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelectionMode}" Value="True">
                                                <Setter Property="Foreground" Value="Cyan"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>
                            <TextBlock Text="Seçim" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    
                    <Rectangle Width="1" Fill="{DynamicResource Brush.Border}" Margin="4,4"/>
                    
                    <ToggleButton IsChecked="{Binding IsDrawingRoute, Mode=TwoWay}" ToolTip="Ray Çiz (Altyapı)">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Line24" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <ui:SymbolIcon.Style>
                                    <Style TargetType="ui:SymbolIcon">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDrawingRoute}" Value="True">
                                                <Setter Property="Foreground" Value="Yellow"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>
                            <TextBlock Text="Ray Çiz" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    
                    <ToggleButton IsChecked="{Binding IsDrawingLogicalRoute, Mode=TwoWay}" ToolTip="Rota Çiz (Yön)">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="ArrowRouting24" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <ui:SymbolIcon.Style>
                                    <Style TargetType="ui:SymbolIcon">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDrawingLogicalRoute}" Value="True">
                                                <Setter Property="Foreground" Value="Cyan"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>
                            <TextBlock Text="Rota Çiz" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    
                    <Rectangle Width="1" Fill="{DynamicResource Brush.Border}" Margin="4,4"/>
                    
                    <ui:Button Command="{Binding UndoRouteNodeCommand}" ToolTip="Geri Al (Ctrl+Z)">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="ArrowUndo24" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text.Primary}"/>
                            <TextBlock Text="Geri Al" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                    
                    <ToggleButton Command="{Binding ToggleOrthogonalModeCommand}" IsChecked="{Binding IsOrthogonalMode, Mode=OneWay}" ToolTip="Dik Açı (Tab)">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Grid24" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <ui:SymbolIcon.Style>
                                    <Style TargetType="ui:SymbolIcon">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOrthogonalMode}" Value="True">
                                                <Setter Property="Foreground" Value="Yellow"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>
                            <TextBlock Text="Dik Açı" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    
                    <ui:Button Command="{Binding ToggleDrawingRouteCommand}" ToolTip="Çizimi Bitir (Sağ Tık)">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Checkmark24" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Success}"/>
                            <TextBlock Text="Bitir" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </TabItem>
            
            <TabItem Header="Görünüm (View)">
                <StackPanel Orientation="Horizontal" Margin="8,4">
                    <ui:Button Command="{Binding LoadImageCommand}" ToolTip="Arkaplan Resmi Ekle">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="ImageAdd24" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text.Primary}"/>
                            <TextBlock Text="Resim Ekle" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                    
                    <ui:Button Command="{Binding RemoveImageCommand}" ToolTip="Seçili Resmi Sil">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Delete24" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Danger}"/>
                            <TextBlock Text="Sil" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                    
                    <ToggleButton IsChecked="{Binding SelectedImage.IsLocked, Mode=TwoWay}" IsEnabled="{Binding HasSelectedImage}" ToolTip="Resmi Kilitle">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="LockClosed24" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <ui:SymbolIcon.Style>
                                    <Style TargetType="ui:SymbolIcon">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedImage.IsLocked}" Value="True">
                                                <Setter Property="Foreground" Value="Orange"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>
                            <TextBlock Text="Kilitle" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    
                    <Rectangle Width="1" Fill="{DynamicResource Brush.Border}" Margin="4,4"/>
                    
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="8,0">
                        <TextBlock Text="Opaklık" FontSize="11" HorizontalAlignment="Center" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4"/>
                        <Slider Minimum="0.1" Maximum="1.0" Value="{Binding SelectedImage.Opacity, Mode=TwoWay}" IsEnabled="{Binding HasSelectedImage}" Width="100"/>
                    </StackPanel>
                    
                    <Rectangle Width="1" Fill="{DynamicResource Brush.Border}" Margin="4,4"/>
                    
                    <ui:Button Command="{Binding RefreshCommand}" ToolTip="Yenile">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Success}"/>
                            <TextBlock Text="Yenile" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                    
                    <ui:Button Command="{Binding SaveLayoutCommand}" ToolTip="Kaydet">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Save24" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Primary}"/>
                            <TextBlock Text="Kaydet" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                    
                    <ui:Button Command="{Binding LoadLayoutCommand}" ToolTip="Yükle">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="FolderOpen24" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text.Primary}"/>
                            <TextBlock Text="Yükle" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </TabItem>
            
            <TabItem Header="Simülasyon (Simulation)">
                <StackPanel Orientation="Horizontal" Margin="8,4">
                    <ToggleButton IsChecked="{Binding IsLiveMode, Mode=TwoWay}" ToolTip="Canlı Mod (Live)">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Live24" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <ui:SymbolIcon.Style>
                                    <Style TargetType="ui:SymbolIcon">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLiveMode}" Value="True">
                                                <Setter Property="Foreground" Value="LimeGreen"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>
                            <TextBlock Text="Canlı Mod" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    
                    <Rectangle Width="1" Fill="{DynamicResource Brush.Border}" Margin="4,4"/>
                    
                    <ui:Button Command="{Binding StartSimulationCommand}" ToolTip="Başlat">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Play24" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="LimeGreen"/>
                            <TextBlock Text="Başlat" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                    
                    <ui:Button Command="{Binding StopSimulationCommand}" ToolTip="Durdur">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Stop24" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4" Foreground="Red"/>
                            <TextBlock Text="Durdur" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </TabItem>
        </TabControl>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left: FeatureManager (SolidWorks Style) -->
                <ColumnDefinition Width="320"/>
                <!-- Right: Editor Area (star) -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left: FeatureManager (SolidWorks Style) -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,0,1,0"
                    Margin="0">
                
                <TabControl Background="Transparent" BorderThickness="0" Padding="0" Margin="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="FontSize" Value="12"/>
                        </Style>
                    </TabControl.Resources>
                    
                    <!-- Unsur AÄŸacÄ± (Feature Tree) -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="TextBulletListTree24" FontSize="16" Margin="0,0,6,0"/>
                                <TextBlock Text="Unsur AÄŸacÄ±"/>
                            </StackPanel>
                        </TabItem.Header>
                        
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Search Box (mock) -->
                            <Border Grid.Row="0" Margin="8" Background="{DynamicResource Brush.Background.Secondary}" CornerRadius="4" Padding="4">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Search24" FontSize="14" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="4,0"/>
                                    <TextBlock Text="Ara..." Foreground="{DynamicResource Brush.Text.Secondary}" FontStyle="Italic" VerticalAlignment="Center" Margin="4,0"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Layers TreeView -->
                            <TreeView Grid.Row="1"
                                      ItemsSource="{Binding Layers}"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      Margin="0"
                                      SelectedItemChanged="TreeView_SelectedItemChanged">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay, FallbackValue=True}"/>
                                        <Setter Property="Padding" Value="2"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}"/>
                                        <Setter Property="ContextMenu">
                                            <Setter.Value>
                                                <ContextMenu>
                                                    <MenuItem Header="Ã–zellikler" Command="{Binding PlacementTarget.Tag.EditLayerPropertiesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    <MenuItem Header="Sil" Command="{Binding PlacementTarget.Tag.RemoveSelectedLayerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                </ContextMenu>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Brush.Accent.Secondary}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Brush.Background.Secondary}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.Resources>
                                    <!-- HierarchicalDataTemplate for LayerGroup -->
                                    <HierarchicalDataTemplate DataType="{x:Type models:LayerGroup}" ItemsSource="{Binding Children}">
                                        <Grid Width="250" Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/> <!-- Visibility -->
                                                <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                                <ColumnDefinition Width="*"/>    <!-- Name -->
                                            </Grid.ColumnDefinitions>
                                            
                                            <ToggleButton Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}" 
                                                          Background="Transparent" BorderThickness="0" Padding="4" Margin="0,0,4,0" Cursor="Hand">
                                                <ui:SymbolIcon Symbol="Eye24" FontSize="14" Opacity="{Binding IsVisible, Converter={StaticResource BoolToOpacityConverter}}"/>
                                            </ToggleButton>
                                            
                                            <ui:SymbolIcon Grid.Column="1" Symbol="Folder24" 
                                                       VerticalAlignment="Center" Margin="0,0,6,0" FontSize="16" Foreground="{DynamicResource Brush.Primary}"/>
                                            
                                            <TextBlock Grid.Column="2" Text="{Binding LayerName}" 
                                                       FontSize="{DynamicResource Font.Body}"
                                                       FontFamily="{DynamicResource Font.Primary}"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </HierarchicalDataTemplate>
                                    
                                    <!-- DataTemplates -->
                                    <DataTemplate DataType="{x:Type electronics:StationInstance}">
                                        <Grid Width="230" Margin="0,1" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Özellikler" Command="{Binding PlacementTarget.Tag.EditLayerPropertiesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="Kod Yaz" Command="{Binding PlacementTarget.Tag.EditCustomCodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="Sil" Command="{Binding PlacementTarget.Tag.RemoveSelectedLayerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                </ContextMenu>
                                            </Grid.ContextMenu>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="2" Margin="0,0,4,0" Cursor="Hand"><ui:SymbolIcon Symbol="Eye24" FontSize="12" Opacity="{Binding IsVisible, Converter={StaticResource BoolToOpacityConverter}}"/></ToggleButton>
                                            <ui:SymbolIcon Grid.Column="1" Symbol="Desktop24" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="14" Foreground="{DynamicResource Brush.Accent.Primary}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Name}" FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                                            <ToggleButton Grid.Column="3" IsChecked="{Binding IsLocked, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand"><ui:SymbolIcon Symbol="LockClosed24" FontSize="12" Opacity="{Binding IsLocked, Converter={StaticResource BoolToOpacityConverter}}"/></ToggleButton>
                                        </Grid>
                                    </DataTemplate>
                                    
                                    <DataTemplate DataType="{x:Type electronics:ComponentInstance}">
                                        <Grid Width="230" Margin="0,1" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="2" Margin="0,0,4,0" Cursor="Hand"><ui:SymbolIcon Symbol="Eye24" FontSize="12" Opacity="{Binding IsVisible, Converter={StaticResource BoolToOpacityConverter}}"/></ToggleButton>
                                            <ui:SymbolIcon Grid.Column="1" Symbol="PlugConnected24" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="14" Foreground="{DynamicResource Brush.Warning}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Name}" FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                                            <ToggleButton Grid.Column="3" IsChecked="{Binding IsLocked, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand"><ui:SymbolIcon Symbol="LockClosed24" FontSize="12" Opacity="{Binding IsLocked, Converter={StaticResource BoolToOpacityConverter}}"/></ToggleButton>
                                        </Grid>
                                    </DataTemplate>
                                    
                                    <DataTemplate DataType="{x:Type electronics:RfidTagInstance}">
                                        <Grid Width="230" Margin="0,1" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="2" Margin="0,0,4,0" Cursor="Hand"><ui:SymbolIcon Symbol="Eye24" FontSize="12" Opacity="{Binding IsVisible, Converter={StaticResource BoolToOpacityConverter}}"/></ToggleButton>
                                            <ui:SymbolIcon Grid.Column="1" Symbol="Tag24" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="14" Foreground="{DynamicResource Brush.Success}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Name}" FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                                            <ToggleButton Grid.Column="3" IsChecked="{Binding IsLocked, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand"><ui:SymbolIcon Symbol="LockClosed24" FontSize="12" Opacity="{Binding IsLocked, Converter={StaticResource BoolToOpacityConverter}}"/></ToggleButton>
                                        </Grid>
                                    </DataTemplate>
                                    
                                    <DataTemplate DataType="{x:Type models:EditorImage}">
                                        <Grid Width="230" Margin="0,1" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="2" Margin="0,0,4,0" Cursor="Hand"><ui:SymbolIcon Symbol="Eye24" FontSize="12" Opacity="{Binding IsVisible, Converter={StaticResource BoolToOpacityConverter}}"/></ToggleButton>
                                            <ui:SymbolIcon Grid.Column="1" Symbol="Image24" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="14" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Name}" FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                                            <ToggleButton Grid.Column="3" IsChecked="{Binding IsLocked, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand"><ui:SymbolIcon Symbol="LockClosed24" FontSize="12" Opacity="{Binding IsLocked, Converter={StaticResource BoolToOpacityConverter}}"/></ToggleButton>
                                        </Grid>
                                    </DataTemplate>
                                    
                                    <DataTemplate DataType="{x:Type electronics:TrackRoute}">
                                        <Grid Width="230" Margin="0,1" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Özellikler" Command="{Binding PlacementTarget.Tag.EditLayerPropertiesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="Sil" Command="{Binding PlacementTarget.Tag.RemoveSelectedLayerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                </ContextMenu>
                                            </Grid.ContextMenu>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="2" Margin="0,0,4,0" Cursor="Hand"><ui:SymbolIcon Symbol="Eye24" FontSize="12" Opacity="{Binding IsVisible, Converter={StaticResource BoolToOpacityConverter}}"/></ToggleButton>
                                            <ui:SymbolIcon Grid.Column="1" Symbol="ArrowRouting24" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="14" Foreground="Yellow"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Name}" FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                                            <ToggleButton Grid.Column="3" IsChecked="{Binding IsCenterLineVisible, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand" ToolTip="Merkez Çizgisini Göster/Gizle"><TextBlock Text="➖" FontSize="12" Foreground="Yellow" Opacity="{Binding IsCenterLineVisible, Converter={StaticResource BoolToOpacityConverter}}"/></ToggleButton>
                                        </Grid>
                                    </DataTemplate>
                                    <DataTemplate DataType="{x:Type electronics:LogicalRoute}">
                                        <Grid Width="230" Margin="0,1" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Özellikler" Command="{Binding PlacementTarget.Tag.EditLayerPropertiesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="Sil" Command="{Binding PlacementTarget.Tag.RemoveSelectedLayerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                </ContextMenu>
                                            </Grid.ContextMenu>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="2" Margin="0,0,4,0" Cursor="Hand"><ui:SymbolIcon Symbol="Eye24" FontSize="12" Opacity="{Binding IsVisible, Converter={StaticResource BoolToOpacityConverter}}"/></ToggleButton>
                                            <ui:SymbolIcon Grid.Column="1" Symbol="ArrowRouting24" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="14" Foreground="Cyan"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Name}" FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                                            <ToggleButton Grid.Column="3" IsChecked="{Binding IsLocked, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand"><ui:SymbolIcon Symbol="LockClosed24" FontSize="12" Opacity="{Binding IsLocked, Converter={StaticResource BoolToOpacityConverter}}"/></ToggleButton>
                                        </Grid>
                                    </DataTemplate>
                                    
                                    <DataTemplate DataType="{x:Type electronics:ModemInstance}">
                                        <Grid Width="230" Margin="0,1" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Özellikler" Command="{Binding PlacementTarget.Tag.EditLayerPropertiesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="Sil" Command="{Binding PlacementTarget.Tag.RemoveSelectedLayerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                </ContextMenu>
                                            </Grid.ContextMenu>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="2" Margin="0,0,4,0" Cursor="Hand"><ui:SymbolIcon Symbol="Eye24" FontSize="12" Opacity="{Binding IsVisible, Converter={StaticResource BoolToOpacityConverter}}"/></ToggleButton>
                                            <ui:SymbolIcon Grid.Column="1" Symbol="Server24" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="14" Foreground="{DynamicResource Brush.Accent.Primary}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Name}" FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                                            <ToggleButton Grid.Column="3" IsChecked="{Binding IsLocked, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand"><ui:SymbolIcon Symbol="LockClosed24" FontSize="12" Opacity="{Binding IsLocked, Converter={StaticResource BoolToOpacityConverter}}"/></ToggleButton>
                                        </Grid>
                                    </DataTemplate>

                                    <DataTemplate DataType="{x:Type electronics:MainPcInstance}">
                                        <Grid Width="230" Margin="0,1" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Özellikler" Command="{Binding PlacementTarget.Tag.EditLayerPropertiesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="Kod Yaz" Command="{Binding PlacementTarget.Tag.EditCustomCodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="Sil" Command="{Binding PlacementTarget.Tag.RemoveSelectedLayerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                </ContextMenu>
                                            </Grid.ContextMenu>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="2" Margin="0,0,4,0" Cursor="Hand"><ui:SymbolIcon Symbol="Eye24" FontSize="12" Opacity="{Binding IsVisible, Converter={StaticResource BoolToOpacityConverter}}"/></ToggleButton>
                                            <ui:SymbolIcon Grid.Column="1" Symbol="Desktop24" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="14" Foreground="{DynamicResource Brush.Success}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Name}" FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                                            <ToggleButton Grid.Column="3" IsChecked="{Binding IsLocked, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="2" Cursor="Hand"><ui:SymbolIcon Symbol="LockClosed24" FontSize="12" Opacity="{Binding IsLocked, Converter={StaticResource BoolToOpacityConverter}}"/></ToggleButton>
                                        </Grid>
                                    </DataTemplate>
                                </TreeView.Resources>
                            </TreeView>
                        </Grid>
                    </TabItem>
                    
                    <!-- Masalar (Palette) -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Cube24" FontSize="16" Margin="0,0,6,0"/>
                                <TextBlock Text="BileÅŸenler"/>
                            </StackPanel>
                        </TabItem.Header>
                        
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <ListBox Grid.Row="0"
                                     ItemsSource="{Binding PaletteItems, Mode=OneWay}"
                                     SelectedItem="{Binding SelectedPaletteItem, Mode=TwoWay}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource Brush.Background.Primary}"
                                                BorderThickness="0"
                                                Padding="8,6"
                                                Margin="2"
                                                CornerRadius="4">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Router24" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource Brush.Primary}"/>
                                                <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            
                            <ui:Button Grid.Row="1" Content="Haritaya Ekle" Command="{Binding AddBoxCommand}" Appearance="Primary" HorizontalAlignment="Stretch" Margin="12"/>
                        </Grid>
                    </TabItem>
                    
                    <!-- Ã–zellikler (Properties) -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Settings24" FontSize="16" Margin="0,0,6,0"/>
                                <TextBlock Text="Ã–zellikler"/>
                            </StackPanel>
                        </TabItem.Header>
                        <Grid>
                            <!-- Future property editor here -->
                            <TextBlock Text="SeÃ§ili eleman Ã¶zellikleri burada gÃ¶rÃ¼necek." TextWrapping="Wrap" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="16" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
            <!-- Middle: Editor Area -->
            <!-- TCP-1.0.2: Editor area with background image display -->
            <!-- TCP-1.0.3: Canvas overlay for placed boxes -->
            <!-- TCP-1.0.4: Viewport transform integration (Zoom/Pan) -->
            <Border x:Name="ViewportContainer"
                    Grid.Column="1"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="16,0,16,16"
                    ClipToBounds="True"
                    MouseWheel="ViewportContainer_MouseWheel"
                    MouseDown="ViewportContainer_MouseDown"
                    PreviewMouseRightButtonDown="ViewportContainer_PreviewMouseRightButtonDown"
                    MouseMove="ViewportContainer_MouseMove"
                    MouseUp="ViewportContainer_MouseUp">
                <Grid>
                    <!-- Viewport Canvas with Transform -->
                    <!-- TCP-1.0.4: This Canvas applies zoom/pan transform to all children -->
                    <Canvas x:Name="ViewportCanvas"
                            Background="Transparent"
                            RenderTransform="{Binding ViewportState.Transform, Mode=OneWay}"
                            Tag="{Binding}">
                        <Canvas.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Seçili Öğeleri Sil" Command="{Binding PlacementTarget.Tag.RemoveSelectedLayerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            </ContextMenu>
                        </Canvas.ContextMenu>
                        
                        <!-- AutoCAD-style Limited Space Grid (Z-Index -1) -->
                        <Rectangle Canvas.Left="-5000" Canvas.Top="-5000" 
                                   Width="10000" Height="10000"
                                   Panel.ZIndex="-1">
                            <Rectangle.Fill>
                                <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing>
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <LineGeometry StartPoint="0,0" EndPoint="40,0"/>
                                                    <LineGeometry StartPoint="0,0" EndPoint="0,40"/>
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                            <GeometryDrawing.Pen>
                                                <!-- Faint grid line -->
                                                <Pen Brush="#33888888" Thickness="0.5"/>
                                            </GeometryDrawing.Pen>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Background Images Container (Z-Index 0) -->
                        <ItemsControl ItemsSource="{Binding EditorImages}" Panel.ZIndex="0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                    <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="{Binding Width}" Height="{Binding Height}"
                                            BorderBrush="{DynamicResource Brush.Accent.Primary}"
                                            BorderThickness="1"
                                            Opacity="{Binding Opacity}"
                                            Background="Transparent">
                                        <Border.InputBindings>
                                            <MouseBinding Gesture="LeftClick" Command="{Binding DataContext.SelectImageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Primary}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Image Source="{Binding ImageSource}"
                                                   Stretch="Uniform"
                                                   IsHitTestVisible="True"
                                                   MouseLeftButtonDown="Image_MouseLeftButtonDown"
                                                   MouseMove="Image_MouseMove"
                                                   MouseLeftButtonUp="Image_MouseLeftButtonUp" />
                                            
                                            <!-- Resizing Thumbs -->
                                            <Thumb x:Name="ThumbTL" Width="12" Height="12" Background="{DynamicResource Brush.Accent.Primary}" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="SizeNWSE" DragDelta="ThumbTL_DragDelta" Margin="-6,-6,0,0">
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                            <Thumb x:Name="ThumbTR" Width="12" Height="12" Background="{DynamicResource Brush.Accent.Primary}" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="SizeNESW" DragDelta="ThumbTR_DragDelta" Margin="0,-6,-6,0">
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                            <Thumb x:Name="ThumbBL" Width="12" Height="12" Background="{DynamicResource Brush.Accent.Primary}" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="SizeNESW" DragDelta="ThumbBL_DragDelta" Margin="-6,0,0,-6">
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                            <Thumb x:Name="ThumbBR" Width="12" Height="12" Background="{DynamicResource Brush.Accent.Primary}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" DragDelta="ThumbBR_DragDelta" Margin="0,0,-6,-6">
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Daisy-Chain Connections Overlay (Z-Index 1) -->
                        <ItemsControl ItemsSource="{Binding DaisyChainLines}" Panel.ZIndex="1">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Path>
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Stroke" Value="#00FFFF" /> <!-- Neon Blue -->
                                                <Setter Property="StrokeThickness" Value="6" />
                                                <Setter Property="Opacity" Value="0.9" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LineType}" Value="Station">
                                                        <Setter Property="Stroke" Value="#FFA500" /> <!-- Orange -->
                                                        <Setter Property="StrokeThickness" Value="4" />
                                                        <Setter Property="Opacity" Value="0.8" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding LineType}" Value="Component">
                                                        <Setter Property="Stroke" Value="#AAAAAA" /> <!-- Gray -->
                                                        <Setter Property="StrokeThickness" Value="2" />
                                                        <Setter Property="StrokeDashArray" Value="4,4" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                        <Path.Data>
                                            <MultiBinding Converter="{StaticResource ConnectionPathConverter}">
                                                <Binding Path="Source"/>
                                                <Binding Path="Target"/>
                                                <Binding Path="Source.X"/>
                                                <Binding Path="Source.Y"/>
                                                <Binding Path="Target.X"/>
                                                <Binding Path="Target.Y"/>
                                            </MultiBinding>
                                        </Path.Data>
                                    </Path>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Track Routes Overlay (Z-Index 0.8) -->
                        <ItemsControl ItemsSource="{Binding Routes}" Panel.ZIndex="0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Canvas Background="Transparent" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                        <Canvas.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Sil" Command="{Binding PlacementTarget.Tag.RemoveSelectedLayerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}" />
                                                <MenuItem Header="Özellikler" Command="{Binding PlacementTarget.Tag.EditLayerPropertiesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}" />
                                            </ContextMenu>
                                        </Canvas.ContextMenu>
                                        <!-- Track Base / Gölge -->
                                        <Path Stroke="#222222" StrokeThickness="20" Opacity="0.4"
                                              Data="{Binding RoutePathData}" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <!-- Traversler (Sleepers) -->
                                        <Path Stroke="#6b4423" StrokeThickness="16" StrokeDashArray="0.2, 0.4" StrokeEndLineCap="Flat" StrokeStartLineCap="Flat" Opacity="0.9"
                                              Data="{Binding RoutePathData}" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        
                                        <!-- Sol Ray -->
                                        <Path Stroke="#C0C0C0" StrokeThickness="2" 
                                              Data="{Binding LeftRailPathData}" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                              
                                        <!-- Sağ Ray -->
                                        <Path Stroke="#C0C0C0" StrokeThickness="2" 
                                              Data="{Binding RightRailPathData}" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <!-- Merkez Çizgi -->
                                        <Path Stroke="Yellow" StrokeThickness="2" Opacity="0.9" StrokeDashArray="2, 2"
                                              Data="{Binding RoutePathData}" Visibility="{Binding IsCenterLineVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <!-- Direction Arrows -->
                                        <Path Data="{Binding DirectionPathData}"
                                              Stroke="White" StrokeThickness="2" />
                                        
                                        <!-- The Nodes -->
                                        <ItemsControl ItemsSource="{Binding Nodes}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Ellipse Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}" 
                                                             Cursor="SizeAll"
                                                             MouseLeftButtonDown="Node_MouseLeftButtonDown"
                                                             MouseMove="Node_MouseMove"
                                                             MouseLeftButtonUp="Node_MouseLeftButtonUp">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="Red" />
                                                                <Setter Property="Width" Value="12" />
                                                                <Setter Property="Height" Value="12" />
                                                                <Setter Property="Margin" Value="-6,-6,0,0" />
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <!-- Rota çizerken TÜM düğümleri göster (ortadaki düğümler) -->
                                                                    <DataTrigger Binding="{Binding DataContext.IsDrawingLogicalRoute, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Setter Property="Fill" Value="Cyan" />
                                                                        <Setter Property="Opacity" Value="0.6" />
                                                                    </DataTrigger>
                                                                    <!-- Rota çizerken Uç noktaları özel göster -->
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding DataContext.IsDrawingLogicalRoute, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True" />
                                                                            <Condition Binding="{Binding IsEndPoint}" Value="True" />
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Setter Property="Fill" Value="DarkBlue" />
                                                                        <Setter Property="Opacity" Value="1.0" />
                                                                        <Setter Property="Width" Value="16" />
                                                                        <Setter Property="Height" Value="16" />
                                                                        <Setter Property="Margin" Value="-8,-8,0,0" />
                                                                    </MultiDataTrigger>
                                                                    <!-- Ray çizerken tüm düğümleri göster -->
                                                                    <DataTrigger Binding="{Binding DataContext.IsDrawingRoute, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                        <Ellipse.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="Cihaz Ata (Makas/Servo)" 
                                                                          Command="{Binding DataContext.BindComponentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                          CommandParameter="{Binding}" />
                                                            </ContextMenu>
                                                        </Ellipse.ContextMenu>
                                                    </Ellipse>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Canvas>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Logical Routes Overlay (Z-Index 2) -->
                        <ItemsControl ItemsSource="{Binding LogicalRoutes}" Panel.ZIndex="2">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Canvas Background="Transparent" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                        <Canvas.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Sil" Command="{Binding PlacementTarget.Tag.RemoveLogicalRouteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}" />
                                            </ContextMenu>
                                        </Canvas.ContextMenu>
                                        
                                        <!-- Logical Route Line -->
                                        <Path Stroke="Cyan" StrokeThickness="4" Opacity="0.8"
                                              Data="{Binding RoutePathData}" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <!-- Direction Arrows -->
                                        <Path Data="{Binding DirectionPathData}"
                                              Fill="White" Stroke="White" StrokeThickness="1" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </Canvas>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Preview Line for Route Drawing -->
                        <Line x:Name="DrawingPreviewLine"
                              Stroke="{DynamicResource Brush.Accent.Primary}"
                              StrokeThickness="2"
                              StrokeDashArray="2,2"
                              Visibility="Collapsed"
                              IsHitTestVisible="False" />

                        <!-- Snap Indicator (Z-Index 5) -->
                        <Ellipse x:Name="SnapIndicator" Width="16" Height="16" 
                                 Fill="White" Opacity="0.9" Panel.ZIndex="5"
                                 Visibility="Collapsed" IsHitTestVisible="False"
                                 Margin="-8,-8,0,0">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="White" BlurRadius="15" ShadowDepth="0"/>
                            </Ellipse.Effect>
                        </Ellipse>

                        <!-- Selection Rectangle (Z-Index 6) -->
                        <Rectangle x:Name="SelectionRectangle"
                                   Stroke="DodgerBlue"
                                   StrokeThickness="1"
                                   StrokeDashArray="4 2"
                                   Fill="#331E90FF"
                                   Visibility="Collapsed"
                                   Panel.ZIndex="6"
                                   IsHitTestVisible="False"/>

                        <!-- Placed Boxes Overlay (Z-Index 2) -->
                        <!-- TCP-1.0.3: Boxes drawn on top of background image -->
                        <!-- TCP-1.0.4: Boxes move WITH the viewport transform -->
                        <ItemsControl ItemsSource="{Binding PlacedBoxes, Mode=OneWay}"
                                      Panel.ZIndex="2">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X, Mode=OneWay}"/>
                                    <Setter Property="Canvas.Top" Value="{Binding Y, Mode=OneWay}"/>
                                    <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Border x:Name="DefaultBox" Background="{DynamicResource Brush.Background.Primary}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="2"
                                            CornerRadius="4"
                                            Padding="12,8"
                                            Width="160"
                                            Height="110"
                                            Cursor="SizeAll"
                                            MouseLeftButtonDown="Box_MouseLeftButtonDown"
                                            MouseMove="Box_MouseMove"
                                            MouseLeftButtonUp="Box_MouseLeftButtonUp">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Primary}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Röle Kontrol (Canlı)" Command="{Binding DataContext.OpenRelayControlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
                                                <MenuItem Header="OTA Yazılım Yükle (Canlı)" Command="{Binding DataContext.OpenOtaUpdateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Name, Mode=OneWay}"
                                                               FontSize="{DynamicResource Font.Body}"
                                                               FontFamily="{DynamicResource Font.Primary}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Brush.Text.Primary}"/>
                                                    <ToggleButton Grid.Column="1" 
                                                                  IsChecked="{Binding IsLocked, Mode=TwoWay}"
                                                                  Padding="10" Margin="4,-4,-4,0" Cursor="Hand" 
                                                                  Background="Transparent" BorderThickness="0"
                                                                  MinWidth="44" MinHeight="44"
                                                                  ToolTip="Kilitle/Aç">
                                                        <TextBlock FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="🔓"/>
                                                                    <Setter Property="Opacity" Value="0.5"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                            <Setter Property="Text" Value="🔒"/>
                                                                            <Setter Property="Opacity" Value="1.0"/>
                                                                        </DataTrigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Opacity" Value="1.0"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </ToggleButton>
                                                </Grid>
                                                <!-- Type + Status line -->
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- LED Indicator -->
                                                    <Ellipse Width="10" Height="10" 
                                                             Fill="{Binding ., Converter={StaticResource LedColorConverter}}"
                                                             Margin="0,0,6,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding LayerType, Converter={StaticResource LayerTypeToIconConverter}}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <Border Background="{DynamicResource Brush.Background.Secondary}"
                                                            BorderBrush="{DynamicResource Brush.Border}"
                                                            BorderThickness="1"
                                                            CornerRadius="2"
                                                            Padding="4,2"
                                                            Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding Type, Mode=OneWay}"
                                                                   FontSize="{DynamicResource Font.Caption}"
                                                                   FontFamily="{DynamicResource Font.Primary}"
                                                                   Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                                    </Border>
                                                    <!-- Status -->
                                                    <TextBlock Text="{Binding IpAddress, Mode=OneWay}"
                                                               FontSize="{DynamicResource Font.Caption}"
                                                               FontFamily="{DynamicResource Font.Primary}"
                                                               Foreground="{DynamicResource Brush.Text.Secondary}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <!-- STATION PINS OVERLAY -->
                                            <!-- Only visible if the item has 'Pins' property (i.e. is a StationInstance) -->
                                            <ItemsControl ItemsSource="{Binding Pins, FallbackValue={x:Null}}" 
                                                          HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Margin="-10,0,-10,-12">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="1" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Ellipse Width="8" Height="8" Fill="#444" Stroke="#888" StrokeThickness="1" ToolTip="{Binding}" Margin="2,0"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                        </Border>
                                        
                                        <!-- NEON LED BOX -->
                                        <Grid x:Name="NeonBox" Visibility="Collapsed" Width="60" Height="80"
                                              Cursor="SizeAll"
                                              MouseLeftButtonDown="Box_MouseLeftButtonDown"
                                              MouseMove="Box_MouseMove"
                                              MouseLeftButtonUp="Box_MouseLeftButtonUp"
                                              Background="Transparent">
                                            
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Sil" Command="{Binding PlacementTarget.Tag.RemoveSelectedLayerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                </ContextMenu>
                                            </Grid.ContextMenu>

                                            <!-- Base Bulb (unpowered) -->
                                            <Path Data="M 30,10 C 10,10 10,40 22,50 L 22,65 C 22,68 38,68 38,65 L 38,50 C 50,40 50,10 30,10 Z" 
                                                  Fill="Transparent" Stroke="{Binding ., Converter={StaticResource LedColorConverter}}" StrokeThickness="2" Opacity="0.5" />
                                            <!-- Socket -->
                                            <Path Data="M 20,65 L 40,65 L 36,75 L 24,75 Z" Fill="#555" />
                                            <Path Data="M 26,75 L 34,75 L 32,80 L 28,80 Z" Fill="#333" />
                                            
                                            <!-- Powered State -->
                                            <Grid x:Name="NeonGlowGrid" Visibility="Collapsed">
                                                <!-- Glow 1 (Outer) -->
                                                <Path Data="M 30,10 C 10,10 10,40 22,50 L 22,65 C 22,68 38,68 38,65 L 38,50 C 50,40 50,10 30,10 Z" 
                                                      Fill="{Binding ., Converter={StaticResource LedColorConverter}}">
                                                    <Path.Effect>
                                                        <BlurEffect Radius="25" />
                                                    </Path.Effect>
                                                </Path>
                                                <!-- Glow 2 (Inner) -->
                                                <Path Data="M 30,10 C 10,10 10,40 22,50 L 22,65 C 22,68 38,68 38,65 L 38,50 C 50,40 50,10 30,10 Z" 
                                                      Fill="{Binding ., Converter={StaticResource LedColorConverter}}">
                                                    <Path.Effect>
                                                        <BlurEffect Radius="10" />
                                                    </Path.Effect>
                                                </Path>
                                                <!-- Bright Center -->
                                                <Path Data="M 30,10 C 10,10 10,40 22,50 L 22,65 C 22,68 38,68 38,65 L 38,50 C 50,40 50,10 30,10 Z" 
                                                      Fill="#FFFFFFFF" Opacity="0.8">
                                                </Path>
                                            </Grid>

                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Brush.Text.Primary}" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-15,0,0"/>
                                        </Grid>
                                        
                                        <!-- Terminal Overlay -->
                                        <Border x:Name="StationConsole" Width="160" Height="60" Margin="0,4,0,0" 
                                                Background="#0f0f0f" CornerRadius="4" 
                                                BorderBrush="#333" BorderThickness="1"
                                                Visibility="Collapsed">
                                            <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding ConsoleLogs, FallbackValue={x:Null}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" Foreground="#00FF00" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Border>
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding LayerType}" Value="Station">
                                            <Setter TargetName="StationConsole" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding LayerType}" Value="MainPC">
                                            <Setter TargetName="StationConsole" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsLed}" Value="True">
                                            <Setter TargetName="DefaultBox" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="NeonBox" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsLed}" Value="True"/>
                                                <Condition Binding="{Binding IsPowered}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="NeonGlowGrid" Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>
                    

                </Grid>
            </Border>
        </Grid>
        
        <!-- Component Bind Popup -->
        <Border Background="#80000000" Visibility="{Binding IsComponentBindPopupOpen, Converter={StaticResource BoolToVisibilityConverter}}" Grid.RowSpan="3" Grid.ColumnSpan="3" Panel.ZIndex="1000">
            <Border Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="300">
                <StackPanel>
                    <TextBlock Text="Makas Cihazı Ata" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Primary}" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Cihaz (Örn: Servo):" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding AvailableComponentsForBinding}" SelectedItem="{Binding SelectedComponentForBinding}" DisplayMemberPath="Name" Margin="0,0,0,20"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button Content="İptal" Command="{Binding CancelComponentBindingCommand}" Appearance="Secondary" Margin="0,0,10,0"/>
                        <ui:Button Content="Kaydet" Command="{Binding SaveComponentBindingCommand}" Appearance="Primary"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</UserControl>


