<UserControl x:Class="TCP.App.Views.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:TCP.App"
             xmlns:viewmodels="clr-namespace:TCP.App.ViewModels"
             xmlns:models="clr-namespace:TCP.App.Models.Editor"
             xmlns:electronics="clr-namespace:TCP.App.Models.Electronics"
             xmlns:converters="clr-namespace:TCP.App.Converters"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="Transparent">
    <!--
        EditorView.xaml - Editor view
        
        TCP-1.0.2: Background Image Load (Editor)
        Bu view editor içeriğini gösterir.
        MVVM Pattern: Sadece UI, hiçbir mantık içermez.
        
        Layout:
        - Editor toolbar (under TopBar)
        - Main editor area with background image display
    -->
    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        <converters:LayerTypeToIconConverter x:Key="LayerTypeToIconConverter"/>
        <converters:ConnectionPathConverter x:Key="ConnectionPathConverter"/>
        <converters:LedColorConverter x:Key="LedColorConverter"/>
        <converters:RoutePathConverter x:Key="RoutePathConverter"/>
    </UserControl.Resources>
    <UserControl.DataContext>
        <viewmodels:EditorViewModel/>
    </UserControl.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <!-- Editor Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Main Content (Palette + Editor Area) -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Editor Toolbar -->
        <!-- TCP-1.0.2: Editor-local toolbar (visible ONLY inside Editor page) -->
        <Border Grid.Row="0"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Buttons -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Status Text -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                

                <!-- Zoom Controls -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <!-- Load Image Button -->
                    <ui:Button Content="Add Image"
                               Command="{Binding LoadImageCommand}"
                               Appearance="Secondary"
                               Margin="0,0,8,0"
                               Cursor="Hand"/>
                    
                    <!-- Remove Selected Image Button -->
                    <ui:Button Content="Remove Image"
                               Command="{Binding RemoveImageCommand}"
                               Appearance="Danger"
                               Margin="0,0,8,0"
                               Cursor="Hand"/>
                    
                    <!-- Lock Button -->
                    <ToggleButton Content="{DynamicResource String.LockImage}"
                                  IsChecked="{Binding SelectedImage.IsLocked, Mode=TwoWay}"
                                  IsEnabled="{Binding HasSelectedImage}"
                                  Margin="0,0,16,0"
                                  Cursor="Hand"/>
                                  
                    <!-- Opacity Slider -->
                    <TextBlock Text="Opacity:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                    <Slider Minimum="0.1" Maximum="1.0" 
                            Value="{Binding SelectedImage.Opacity, Mode=TwoWay}"
                            IsEnabled="{Binding HasSelectedImage}"
                            Width="100" VerticalAlignment="Center" Margin="0,0,16,0"/>

                    <!-- Rota Çiz Button -->
                    <ToggleButton Content="Rota Çiz (Spline)"
                                  IsChecked="{Binding IsDrawingRoute, Mode=TwoWay}"
                                  Margin="0,0,16,0"
                                  Cursor="Hand">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Foreground" Value="Yellow"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>

                    <ToggleButton Content="Canlı Mod (Live)"
                                  IsChecked="{Binding IsLiveMode, Mode=TwoWay}"
                                  Margin="0,0,16,0"
                                  Cursor="Hand">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Foreground" Value="LimeGreen"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>

                    <!-- Save / Load Layout -->
                    <ui:Button Content="Yenile"
                               Command="{Binding RefreshCommand}"
                               Appearance="Success"
                               Margin="0,0,8,0"
                               Cursor="Hand"/>
                    <ui:Button Content="Save Page"
                               Command="{Binding SaveLayoutCommand}"
                               Appearance="Primary"
                               Margin="0,0,8,0"
                               Cursor="Hand"/>
                    <ui:Button Content="Load Page"
                               Command="{Binding LoadLayoutCommand}"
                               Appearance="Secondary"
                               Margin="0,0,16,0"
                               Cursor="Hand"/>
                    
                    <Border Background="{DynamicResource Brush.Background.Secondary}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="▶ Simülasyonu Başlat" 
                                    Command="{Binding StartSimulationCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="LimeGreen"
                                    FontWeight="SemiBold"
                                    Padding="12,8"
                                    Cursor="Hand"/>
                            <Rectangle Width="1" Fill="{DynamicResource Brush.Border}" Margin="0,4"/>
                            <Button Content="⏹ Durdur" 
                                    Command="{Binding StopSimulationCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="Red"
                                    FontWeight="SemiBold"
                                    Padding="12,8"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </Border>
                </StackPanel>                
                <!-- Status Text -->
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText, Mode=OneWay, FallbackValue='No image loaded'}"
                           FontSize="{DynamicResource Font.Caption}"
                           FontFamily="{DynamicResource Font.Primary}"
                           Foreground="{DynamicResource Brush.Text.Secondary}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="16,0,0,0"/>
            </Grid>
        </Border>
        
        <!-- Main Content: 3-column layout (Palette left, Editor center, Layers right) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left: Palette Panel (fixed width) -->
                <ColumnDefinition Width="260"/>
                <!-- Middle: Editor Area (star) -->
                <ColumnDefinition Width="*"/>
                <!-- Right: Layers Panel (fixed width) -->
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left: Palette Panel -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    Margin="16,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <!-- Header -->
                        <RowDefinition Height="Auto"/>
                        <!-- Board List -->
                        <RowDefinition Height="*"/>
                        <!-- Add Button -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header: Palette -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource Brush.Background.Secondary}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <TextBlock Text="Palette (Masalar)"
                                   FontSize="{DynamicResource Font.Heading.Small}"
                                   FontFamily="{DynamicResource Font.Primary}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text.Primary}"/>
                    </Border>
                    
                    <!-- Board List -->
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding PaletteItems, Mode=OneWay}"
                             SelectedItem="{Binding SelectedPaletteItem, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Margin="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Brush.Background.Primary}"
                                        BorderThickness="0"
                                        Padding="12,8"
                                        Margin="2"
                                        CornerRadius="4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📶"
                                                   FontSize="{DynamicResource Font.Body}"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="{DynamicResource Font.Body}"
                                                   FontFamily="{DynamicResource Font.Primary}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderThickness="0"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource Brush.Border}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource Brush.Accent.Primary}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                    
                    <!-- Add to Map Button -->
                    <ui:Button Grid.Row="2"
                               Content="Add to Map"
                               Command="{Binding AddBoxCommand}"
                               Appearance="Primary"
                               HorizontalAlignment="Stretch"
                               Margin="16"
                               Cursor="Hand"/>
                </Grid>
            </Border>
            
            <!-- Right: Layers & Properties Panel -->
            <Grid Grid.Column="2" Margin="16,0,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/> <!-- Layers Tree -->
                    <RowDefinition Height="Auto"/> <!-- Properties -->
                </Grid.RowDefinitions>

                <!-- Layers Panel -->
                <Border Grid.Row="0"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- Header -->
                            <RowDefinition Height="Auto"/>
                            <!-- Layers List -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header: Layers -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource Brush.Background.Secondary}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="0,0,0,1"
                                Padding="16,12">
                            <TextBlock Text="Layers"
                                       FontSize="{DynamicResource Font.Heading.Small}"
                                       FontFamily="{DynamicResource Font.Primary}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.Text.Primary}"/>
                        </Border>
                        
                        <!-- Layers TreeView -->
                        <TreeView Grid.Row="1"
                                  ItemsSource="{Binding Layers}"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  Margin="0"
                                  SelectedItemChanged="TreeView_SelectedItemChanged">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                    <Setter Property="IsExpanded" Value="True"/>
                                    <Setter Property="Padding" Value="4"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}"/>
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu>
                                                <MenuItem Header="Özellikler" Command="{Binding PlacementTarget.Tag.EditLayerPropertiesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="Sil" Command="{Binding PlacementTarget.Tag.RemoveSelectedLayerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Accent.Secondary}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Border}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.Resources>
                                <!-- HierarchicalDataTemplate for LayerGroup -->
                                <HierarchicalDataTemplate DataType="{x:Type models:LayerGroup}" ItemsSource="{Binding Children}">
                                    <Grid Width="230">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/> <!-- Visibility -->
                                            <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                            <ColumnDefinition Width="*"/>    <!-- Name -->
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Visibility Toggle -->
                                        <ToggleButton Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}" 
                                                      Background="Transparent" BorderThickness="0" Padding="4" Margin="0,0,4,0" Cursor="Hand">
                                            <TextBlock Text="👁" FontSize="12" Opacity="{Binding IsVisible, Converter={StaticResource BoolToOpacityConverter}}"/>
                                        </ToggleButton>
                                        
                                        <!-- Folder Icon -->
                                        <TextBlock Grid.Column="1" Text="📁" 
                                                   VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                        
                                        <!-- Name -->
                                        <TextBlock Grid.Column="2" Text="{Binding LayerName}" 
                                                   FontSize="{DynamicResource Font.Body}"
                                                   FontFamily="{DynamicResource Font.Primary}"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </HierarchicalDataTemplate>
                                
                                <!-- DataTemplate for StationInstance -->
                                <DataTemplate DataType="{x:Type electronics:StationInstance}">
                                    <Grid Width="210">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/> <!-- Visibility -->
                                            <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                            <ColumnDefinition Width="*"/>    <!-- Name -->
                                            <ColumnDefinition Width="Auto"/> <!-- Lock -->
                                        </Grid.ColumnDefinitions>
                                        
                                        <ToggleButton Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}" 
                                                      Background="Transparent" BorderThickness="0" Padding="8" Margin="0,0,4,0" Cursor="Hand">
                                            <TextBlock Text="👁" FontSize="16" Opacity="{Binding IsVisible, Converter={StaticResource BoolToOpacityConverter}}"/>
                                        </ToggleButton>
                                        
                                        <TextBlock Grid.Column="1" Text="💻" 
                                                   VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                        
                                        <TextBlock Grid.Column="2" Text="{Binding Name}" 
                                                   FontSize="{DynamicResource Font.Body}"
                                                   FontFamily="{DynamicResource Font.Primary}"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                   VerticalAlignment="Center"/>
                                                   
                                        <ToggleButton Grid.Column="3" IsChecked="{Binding IsLocked, Mode=TwoWay}" 
                                                      Background="Transparent" BorderThickness="0" Padding="8" Margin="0,0,4,0" Cursor="Hand">
                                            <TextBlock Text="🔒" FontSize="16" Opacity="{Binding IsLocked, Converter={StaticResource BoolToOpacityConverter}}"/>
                                        </ToggleButton>
                                    </Grid>
                                </DataTemplate>

                                <!-- DataTemplate for ComponentInstance -->
                                <DataTemplate DataType="{x:Type electronics:ComponentInstance}">
                                    <Grid Width="210">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/> <!-- Visibility -->
                                            <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                            <ColumnDefinition Width="*"/>    <!-- Name -->
                                            <ColumnDefinition Width="Auto"/> <!-- Lock -->
                                        </Grid.ColumnDefinitions>
                                        
                                        <ToggleButton Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}" 
                                                      Background="Transparent" BorderThickness="0" Padding="8" Margin="0,0,4,0" Cursor="Hand">
                                            <TextBlock Text="👁" FontSize="16" Opacity="{Binding IsVisible, Converter={StaticResource BoolToOpacityConverter}}"/>
                                        </ToggleButton>
                                        
                                        <TextBlock Grid.Column="1" Text="🔌" 
                                                   VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                        
                                        <TextBlock Grid.Column="2" Text="{Binding Name}" 
                                                   FontSize="{DynamicResource Font.Body}"
                                                   FontFamily="{DynamicResource Font.Primary}"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                   VerticalAlignment="Center"/>
                                                   
                                        <ToggleButton Grid.Column="3" IsChecked="{Binding IsLocked, Mode=TwoWay}" 
                                                      Background="Transparent" BorderThickness="0" Padding="8" Margin="0,0,4,0" Cursor="Hand">
                                            <TextBlock Text="🔒" FontSize="16" Opacity="{Binding IsLocked, Converter={StaticResource BoolToOpacityConverter}}"/>
                                        </ToggleButton>
                                    </Grid>
                                </DataTemplate>
                                <!-- DataTemplate for RfidTagInstance -->
                                <DataTemplate DataType="{x:Type electronics:RfidTagInstance}">
                                    <Grid Width="210">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/> <!-- Visibility -->
                                            <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                            <ColumnDefinition Width="*"/>    <!-- Name -->
                                            <ColumnDefinition Width="Auto"/> <!-- Lock -->
                                        </Grid.ColumnDefinitions>
                                        
                                        <ToggleButton Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}" 
                                                      Background="Transparent" BorderThickness="0" Padding="8" Margin="0,0,4,0" Cursor="Hand">
                                            <TextBlock Text="👁" FontSize="16" Opacity="{Binding IsVisible, Converter={StaticResource BoolToOpacityConverter}}"/>
                                        </ToggleButton>
                                        
                                        <TextBlock Grid.Column="1" Text="💳" 
                                                   VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                        
                                        <TextBlock Grid.Column="2" Text="{Binding Name}" 
                                                   FontSize="{DynamicResource Font.Body}"
                                                   FontFamily="{DynamicResource Font.Primary}"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                   VerticalAlignment="Center"/>
                                                   
                                        <ToggleButton Grid.Column="3" IsChecked="{Binding IsLocked, Mode=TwoWay}" 
                                                      Background="Transparent" BorderThickness="0" Padding="8" Margin="0,0,4,0" Cursor="Hand">
                                            <TextBlock Text="🔒" FontSize="16" Opacity="{Binding IsLocked, Converter={StaticResource BoolToOpacityConverter}}"/>
                                        </ToggleButton>
                                    </Grid>
                                </DataTemplate>
                                
                                <DataTemplate DataType="{x:Type models:EditorImage}">
                                    <Grid Width="210">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/> <!-- Visibility -->
                                            <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                            <ColumnDefinition Width="*"/>    <!-- Name -->
                                            <ColumnDefinition Width="Auto"/> <!-- Lock -->
                                        </Grid.ColumnDefinitions>
                                        
                                        <ToggleButton Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}" 
                                                      Background="Transparent" BorderThickness="0" Padding="4" Margin="0,0,4,0" Cursor="Hand">
                                            <TextBlock Text="👁" FontSize="12" Opacity="{Binding IsVisible, Converter={StaticResource BoolToOpacityConverter}}"/>
                                        </ToggleButton>
                                        
                                        <TextBlock Grid.Column="1" Text="🖼" 
                                                   VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                        
                                        <TextBlock Grid.Column="2" Text="{Binding Name}" 
                                                   FontSize="{DynamicResource Font.Body}"
                                                   FontFamily="{DynamicResource Font.Primary}"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                   VerticalAlignment="Center"/>
                                                   
                                        <ToggleButton Grid.Column="3" IsChecked="{Binding IsLocked, Mode=TwoWay}" 
                                                      Background="Transparent" BorderThickness="0" Padding="4" Margin="0,0,4,0" Cursor="Hand">
                                            <TextBlock Text="🔒" FontSize="12" Opacity="{Binding IsLocked, Converter={StaticResource BoolToOpacityConverter}}"/>
                                        </ToggleButton>
                                    </Grid>
                                </DataTemplate>

                                <DataTemplate DataType="{x:Type electronics:TrackRoute}">
                                    <Grid Width="210">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/> <!-- Visibility -->
                                            <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                            <ColumnDefinition Width="*"/>    <!-- Name -->
                                            <ColumnDefinition Width="Auto"/> <!-- Center Line Toggle -->
                                        </Grid.ColumnDefinitions>
                                        
                                        <ToggleButton Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}" 
                                                      Background="Transparent" BorderThickness="0" Padding="8" Margin="0,0,4,0" Cursor="Hand">
                                            <TextBlock Text="👁" FontSize="16" Opacity="{Binding IsVisible, Converter={StaticResource BoolToOpacityConverter}}"/>
                                        </ToggleButton>
                                        
                                        <TextBlock Grid.Column="1" Text="🛤" 
                                                   VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                        
                                        <TextBlock Grid.Column="2" Text="{Binding Name}" 
                                                   FontSize="{DynamicResource Font.Body}"
                                                   FontFamily="{DynamicResource Font.Primary}"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                   VerticalAlignment="Center"/>
                                                   
                                        <!-- Center line toggle -->
                                        <ToggleButton Grid.Column="3" IsChecked="{Binding IsCenterLineVisible, Mode=TwoWay}" 
                                                      Background="Transparent" BorderThickness="0" Padding="8" Margin="0,0,4,0" Cursor="Hand" ToolTip="Merkez Çizgisini Göster/Gizle">
                                            <TextBlock Text="➖" FontSize="16" Foreground="Yellow" Opacity="{Binding IsCenterLineVisible, Converter={StaticResource BoolToOpacityConverter}}"/>
                                        </ToggleButton>
                                    </Grid>
                                </DataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- Middle: Editor Area -->
            <!-- TCP-1.0.2: Editor area with background image display -->
            <!-- TCP-1.0.3: Canvas overlay for placed boxes -->
            <!-- TCP-1.0.4: Viewport transform integration (Zoom/Pan) -->
            <Border x:Name="ViewportContainer"
                    Grid.Column="1"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="16,0,16,16"
                    ClipToBounds="True"
                    MouseWheel="ViewportContainer_MouseWheel"
                    MouseDown="ViewportContainer_MouseDown"
                    MouseMove="ViewportContainer_MouseMove"
                    MouseUp="ViewportContainer_MouseUp">
                <Grid>
                    <!-- Viewport Canvas with Transform -->
                    <!-- TCP-1.0.4: This Canvas applies zoom/pan transform to all children -->
                    <Canvas x:Name="ViewportCanvas"
                            Background="Transparent"
                            RenderTransform="{Binding ViewportState.Transform, Mode=OneWay}"
                            RenderTransformOrigin="0.5,0.5">
                        
                        <!-- AutoCAD-style Limited Space Grid (Z-Index -1) -->
                        <Rectangle Canvas.Left="-5000" Canvas.Top="-5000" 
                                   Width="10000" Height="10000"
                                   Panel.ZIndex="-1">
                            <Rectangle.Fill>
                                <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing>
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <LineGeometry StartPoint="0,0" EndPoint="40,0"/>
                                                    <LineGeometry StartPoint="0,0" EndPoint="0,40"/>
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                            <GeometryDrawing.Pen>
                                                <!-- Faint grid line -->
                                                <Pen Brush="#33888888" Thickness="0.5"/>
                                            </GeometryDrawing.Pen>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Background Images Container (Z-Index 0) -->
                        <ItemsControl ItemsSource="{Binding EditorImages}"
                                      Panel.ZIndex="0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                    <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="{Binding Width}" Height="{Binding Height}"
                                            BorderBrush="{DynamicResource Brush.Accent.Primary}"
                                            BorderThickness="1"
                                            Opacity="{Binding Opacity}"
                                            Background="Transparent">
                                        <Border.InputBindings>
                                            <MouseBinding Gesture="LeftClick" Command="{Binding DataContext.SelectImageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Primary}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Image Source="{Binding ImageSource}"
                                                   Stretch="Uniform"
                                                   IsHitTestVisible="True"
                                                   MouseLeftButtonDown="Image_MouseLeftButtonDown"
                                                   MouseMove="Image_MouseMove"
                                                   MouseLeftButtonUp="Image_MouseLeftButtonUp" />
                                            
                                            <!-- Resizing Thumbs -->
                                            <Thumb x:Name="ThumbTL" Width="12" Height="12" Background="{DynamicResource Brush.Accent.Primary}" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="SizeNWSE" DragDelta="ThumbTL_DragDelta" Margin="-6,-6,0,0">
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                            <Thumb x:Name="ThumbTR" Width="12" Height="12" Background="{DynamicResource Brush.Accent.Primary}" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="SizeNESW" DragDelta="ThumbTR_DragDelta" Margin="0,-6,-6,0">
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                            <Thumb x:Name="ThumbBL" Width="12" Height="12" Background="{DynamicResource Brush.Accent.Primary}" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="SizeNESW" DragDelta="ThumbBL_DragDelta" Margin="-6,0,0,-6">
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                            <Thumb x:Name="ThumbBR" Width="12" Height="12" Background="{DynamicResource Brush.Accent.Primary}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" DragDelta="ThumbBR_DragDelta" Margin="0,0,-6,-6">
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Daisy-Chain Connections Overlay (Z-Index 1) -->
                        <ItemsControl ItemsSource="{Binding DaisyChainLines}" Panel.ZIndex="1">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Path>
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Stroke" Value="#00FFFF" /> <!-- Neon Blue -->
                                                <Setter Property="StrokeThickness" Value="6" />
                                                <Setter Property="Opacity" Value="0.9" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LineType}" Value="Station">
                                                        <Setter Property="Stroke" Value="#FFA500" /> <!-- Orange -->
                                                        <Setter Property="StrokeThickness" Value="4" />
                                                        <Setter Property="Opacity" Value="0.8" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding LineType}" Value="Component">
                                                        <Setter Property="Stroke" Value="#AAAAAA" /> <!-- Gray -->
                                                        <Setter Property="StrokeThickness" Value="2" />
                                                        <Setter Property="StrokeDashArray" Value="4,4" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                        <Path.Data>
                                            <MultiBinding Converter="{StaticResource ConnectionPathConverter}">
                                                <Binding Path="Source"/>
                                                <Binding Path="Target"/>
                                                <Binding Path="Source.X"/>
                                                <Binding Path="Source.Y"/>
                                                <Binding Path="Target.X"/>
                                                <Binding Path="Target.Y"/>
                                            </MultiBinding>
                                        </Path.Data>
                                    </Path>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Track Routes Overlay (Z-Index 0.8) -->
                        <ItemsControl ItemsSource="{Binding Routes}" Panel.ZIndex="0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Canvas>
                                        <!-- Track Base / Gölge -->
                                        <Path Stroke="#222222" StrokeThickness="20" Opacity="0.4"
                                              Data="{Binding RoutePathData}" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <!-- Traversler (Sleepers) -->
                                        <Path Stroke="#6b4423" StrokeThickness="16" StrokeDashArray="0.2, 0.4" StrokeEndLineCap="Flat" StrokeStartLineCap="Flat" Opacity="0.9"
                                              Data="{Binding RoutePathData}" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        
                                        <!-- Sol Ray -->
                                        <Path Stroke="#C0C0C0" StrokeThickness="2" 
                                              Data="{Binding LeftRailPathData}" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                              
                                        <!-- Sağ Ray -->
                                        <Path Stroke="#C0C0C0" StrokeThickness="2" 
                                              Data="{Binding RightRailPathData}" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <!-- Merkez Çizgi -->
                                        <Path Stroke="Yellow" StrokeThickness="2" Opacity="0.9" StrokeDashArray="2, 2"
                                              Data="{Binding RoutePathData}" Visibility="{Binding IsCenterLineVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        
                                        <!-- The Nodes -->
                                        <ItemsControl ItemsSource="{Binding Nodes}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Ellipse Width="8" Height="8" Fill="Red" 
                                                             Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}" 
                                                             Margin="-4,-4,0,0" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Canvas>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Placed Boxes Overlay (Z-Index 2) -->
                        <!-- TCP-1.0.3: Boxes drawn on top of background image -->
                        <!-- TCP-1.0.4: Boxes move WITH the viewport transform -->
                        <ItemsControl ItemsSource="{Binding PlacedBoxes, Mode=OneWay}"
                                      Panel.ZIndex="2">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X, Mode=OneWay}"/>
                                    <Setter Property="Canvas.Top" Value="{Binding Y, Mode=OneWay}"/>
                                    <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Border x:Name="DefaultBox" Background="{DynamicResource Brush.Background.Primary}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="2"
                                            CornerRadius="4"
                                            Padding="12,8"
                                            Width="160"
                                            Height="110"
                                            Cursor="SizeAll"
                                            MouseLeftButtonDown="Box_MouseLeftButtonDown"
                                            MouseMove="Box_MouseMove"
                                            MouseLeftButtonUp="Box_MouseLeftButtonUp">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.Primary}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Röle Kontrol (Canlı)" Command="{Binding DataContext.OpenRelayControlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
                                                <MenuItem Header="OTA Yazılım Yükle (Canlı)" Command="{Binding DataContext.OpenOtaUpdateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Name, Mode=OneWay}"
                                                               FontSize="{DynamicResource Font.Body}"
                                                               FontFamily="{DynamicResource Font.Primary}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Brush.Text.Primary}"/>
                                                    <ToggleButton Grid.Column="1" 
                                                                  IsChecked="{Binding IsLocked, Mode=TwoWay}"
                                                                  Padding="10" Margin="4,-4,-4,0" Cursor="Hand" 
                                                                  Background="Transparent" BorderThickness="0"
                                                                  MinWidth="44" MinHeight="44"
                                                                  ToolTip="Kilitle/Aç">
                                                        <TextBlock FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="🔓"/>
                                                                    <Setter Property="Opacity" Value="0.5"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                            <Setter Property="Text" Value="🔒"/>
                                                                            <Setter Property="Opacity" Value="1.0"/>
                                                                        </DataTrigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Opacity" Value="1.0"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </ToggleButton>
                                                </Grid>
                                                <!-- Type + Status line -->
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- LED Indicator -->
                                                    <Ellipse Width="10" Height="10" 
                                                             Fill="{Binding ., Converter={StaticResource LedColorConverter}}"
                                                             Margin="0,0,6,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding LayerType, Converter={StaticResource LayerTypeToIconConverter}}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <Border Background="{DynamicResource Brush.Background.Secondary}"
                                                            BorderBrush="{DynamicResource Brush.Border}"
                                                            BorderThickness="1"
                                                            CornerRadius="2"
                                                            Padding="4,2"
                                                            Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding Type, Mode=OneWay}"
                                                                   FontSize="{DynamicResource Font.Caption}"
                                                                   FontFamily="{DynamicResource Font.Primary}"
                                                                   Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                                    </Border>
                                                    <!-- Status -->
                                                    <TextBlock Text="{Binding IpAddress, Mode=OneWay}"
                                                               FontSize="{DynamicResource Font.Caption}"
                                                               FontFamily="{DynamicResource Font.Primary}"
                                                               Foreground="{DynamicResource Brush.Text.Secondary}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <!-- STATION PINS OVERLAY -->
                                            <!-- Only visible if the item has 'Pins' property (i.e. is a StationInstance) -->
                                            <ItemsControl ItemsSource="{Binding Pins, FallbackValue={x:Null}}" 
                                                          HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Margin="-10,0,-10,-12">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="1" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Ellipse Width="8" Height="8" Fill="#444" Stroke="#888" StrokeThickness="1" ToolTip="{Binding}" Margin="2,0"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                        </Border>
                                        
                                        <!-- NEON LED BOX -->
                                        <Grid x:Name="NeonBox" Visibility="Collapsed" Width="60" Height="80"
                                              Cursor="SizeAll"
                                              MouseLeftButtonDown="Box_MouseLeftButtonDown"
                                              MouseMove="Box_MouseMove"
                                              MouseLeftButtonUp="Box_MouseLeftButtonUp"
                                              Background="Transparent">
                                            
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Sil" Command="{Binding PlacementTarget.Tag.RemoveSelectedLayerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                </ContextMenu>
                                            </Grid.ContextMenu>

                                            <!-- Base Bulb (unpowered) -->
                                            <Path Data="M 30,10 C 10,10 10,40 22,50 L 22,65 C 22,68 38,68 38,65 L 38,50 C 50,40 50,10 30,10 Z" 
                                                  Fill="Transparent" Stroke="{Binding ., Converter={StaticResource LedColorConverter}}" StrokeThickness="2" Opacity="0.5" />
                                            <!-- Socket -->
                                            <Path Data="M 20,65 L 40,65 L 36,75 L 24,75 Z" Fill="#555" />
                                            <Path Data="M 26,75 L 34,75 L 32,80 L 28,80 Z" Fill="#333" />
                                            
                                            <!-- Powered State -->
                                            <Grid x:Name="NeonGlowGrid" Visibility="Collapsed">
                                                <!-- Glow 1 (Outer) -->
                                                <Path Data="M 30,10 C 10,10 10,40 22,50 L 22,65 C 22,68 38,68 38,65 L 38,50 C 50,40 50,10 30,10 Z" 
                                                      Fill="{Binding ., Converter={StaticResource LedColorConverter}}">
                                                    <Path.Effect>
                                                        <BlurEffect Radius="25" />
                                                    </Path.Effect>
                                                </Path>
                                                <!-- Glow 2 (Inner) -->
                                                <Path Data="M 30,10 C 10,10 10,40 22,50 L 22,65 C 22,68 38,68 38,65 L 38,50 C 50,40 50,10 30,10 Z" 
                                                      Fill="{Binding ., Converter={StaticResource LedColorConverter}}">
                                                    <Path.Effect>
                                                        <BlurEffect Radius="10" />
                                                    </Path.Effect>
                                                </Path>
                                                <!-- Bright Center -->
                                                <Path Data="M 30,10 C 10,10 10,40 22,50 L 22,65 C 22,68 38,68 38,65 L 38,50 C 50,40 50,10 30,10 Z" 
                                                      Fill="#FFFFFFFF" Opacity="0.8">
                                                </Path>
                                            </Grid>

                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Brush.Text.Primary}" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-15,0,0"/>
                                        </Grid>
                                        
                                        <!-- Terminal Overlay -->
                                        <Border x:Name="StationConsole" Width="160" Height="60" Margin="0,4,0,0" 
                                                Background="#0f0f0f" CornerRadius="4" 
                                                BorderBrush="#333" BorderThickness="1"
                                                Visibility="Collapsed">
                                            <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding ConsoleLogs, FallbackValue={x:Null}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" Foreground="#00FF00" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Border>
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding LayerType}" Value="Station">
                                            <Setter TargetName="StationConsole" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding LayerType}" Value="MainPC">
                                            <Setter TargetName="StationConsole" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsLed}" Value="True">
                                            <Setter TargetName="DefaultBox" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="NeonBox" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsLed}" Value="True"/>
                                                <Condition Binding="{Binding IsPowered}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="NeonGlowGrid" Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>
                    

                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

