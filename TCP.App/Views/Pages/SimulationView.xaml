<UserControl x:Class="TCP.App.Views.Pages.SimulationView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:viewmodels="clr-namespace:TCP.App.ViewModels"
      xmlns:converters="clr-namespace:TCP.App.Converters"
      xmlns:electronics="clr-namespace:TCP.App.Models.Electronics"
      d:DataContext="{d:DesignInstance Type=viewmodels:SimulationViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:ConnectionPathConverter x:Key="ConnectionPathConverter"/>
        <converters:LedColorConverter x:Key="LedColorConverter"/>
        <converters:LayerTypeToIconConverter x:Key="LayerTypeToIconConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.Background.Secondary}" CornerRadius="6" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🚆 Simülasyon" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                
                <ui:Button Content="Harita Yükle" Icon="{ui:SymbolIcon FolderOpen24}" Appearance="Primary" Margin="0,0,20,0" Command="{Binding LoadLayoutCommand}"/>
                <ui:Button Content="Başlat" Icon="{ui:SymbolIcon Play24}" Appearance="Success" Margin="0,0,10,0" Command="{Binding StartSimulationCommand}"/>
                <ui:Button Content="Durdur" Icon="{ui:SymbolIcon Stop24}" Appearance="Danger" Command="{Binding StopSimulationCommand}"/>
                
                <TextBlock Text="{Binding SimulationStatus}" Margin="20,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource Brush.Text.Secondary}"/>
            </StackPanel>
        </Border>

        <!-- Main View Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Map View (ReadOnly) -->
            <Border Grid.Column="0" Background="{DynamicResource Brush.Background.Tertiary}" CornerRadius="6" Margin="0,0,10,0" ClipToBounds="True">
                <Grid>
                    <!-- Background Grid -->
                    <Border Opacity="0.1">
                        <Border.Background>
                            <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing Geometry="M0,0 L40,0 L40,40 L0,40Z">
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="White" Thickness="0.5"/>
                                        </GeometryDrawing.Pen>
                                    </GeometryDrawing>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Border.Background>
                    </Border>
                    
                    <Viewbox Stretch="Uniform">
                        <Canvas x:Name="SimCanvas" Width="1920" Height="1080">
                            <!-- Background Images Container -->
                            <ItemsControl ItemsSource="{Binding EditorImages}" Panel.ZIndex="0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                        <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="{Binding Width}" Height="{Binding Height}" Opacity="{Binding Opacity}">
                                            <Image Source="{Binding ImageSource}" Stretch="Uniform" IsHitTestVisible="False"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Daisy-Chain Connections Overlay -->
                            <ItemsControl ItemsSource="{Binding DaisyChainLines}" Panel.ZIndex="0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Path>
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Stroke" Value="#00FFFF" />
                                                    <Setter Property="StrokeThickness" Value="6" />
                                                    <Setter Property="Opacity" Value="0.9" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LineType}" Value="Station">
                                                            <Setter Property="Stroke" Value="#FFA500" />
                                                            <Setter Property="StrokeThickness" Value="4" />
                                                            <Setter Property="StrokeDashArray" Value="2,2" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding LineType}" Value="Component">
                                                            <Setter Property="Stroke" Value="#AAAAAA" />
                                                            <Setter Property="StrokeThickness" Value="2" />
                                                            <Setter Property="StrokeDashArray" Value="4,4" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                            <Path.Data>
                                                <MultiBinding Converter="{StaticResource ConnectionPathConverter}">
                                                    <Binding Path="Source.X"/>
                                                    <Binding Path="Source.Y"/>
                                                    <Binding Path="Target.X"/>
                                                    <Binding Path="Target.Y"/>
                                                </MultiBinding>
                                            </Path.Data>
                                        </Path>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Track Routes Overlay -->
                            <ItemsControl ItemsSource="{Binding Routes}" Panel.ZIndex="0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Canvas>
                                            <!-- Track Base / Gölge -->
                                            <Path Stroke="#222222" StrokeThickness="20" Opacity="0.4"
                                                  Data="{Binding RoutePathData}" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                                            <!-- Traversler (Sleepers) -->
                                            <Path Stroke="#6b4423" StrokeThickness="16" StrokeDashArray="0.2, 0.4" StrokeEndLineCap="Flat" StrokeStartLineCap="Flat" Opacity="0.9"
                                                  Data="{Binding RoutePathData}" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            
                                            <!-- Sol Ray -->
                                            <Path Stroke="#C0C0C0" StrokeThickness="2" 
                                                  Data="{Binding LeftRailPathData}" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                  
                                            <!-- Sağ Ray -->
                                            <Path Stroke="#C0C0C0" StrokeThickness="2" 
                                                  Data="{Binding RightRailPathData}" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                                            <!-- Merkez Çizgi -->
                                            <Path Stroke="Yellow" StrokeThickness="2" Opacity="0.9" StrokeDashArray="2, 2"
                                                  Data="{Binding RoutePathData}" Visibility="{Binding IsCenterLineVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Placed Boxes Overlay -->
                            <ItemsControl ItemsSource="{Binding PlacedBoxes}" Panel.ZIndex="2">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X, Mode=OneWay}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y, Mode=OneWay}"/>
                                        <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource Brush.Surface}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="2"
                                                CornerRadius="4"
                                                Padding="12,8"
                                                MinWidth="150"
                                                MaxWidth="200"
                                                Opacity="0.9">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name, Mode=OneWay}"
                                                           FontSize="{DynamicResource Font.Body}"
                                                           FontFamily="{DynamicResource Font.Primary}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Text.Primary}"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- LED Indicator -->
                                                    <Ellipse Width="10" Height="10" 
                                                             Fill="{Binding ., Converter={StaticResource LedColorConverter}}"
                                                             Margin="0,0,6,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding LayerType, Converter={StaticResource LayerTypeToIconConverter}}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <Border Background="{DynamicResource Brush.Background.Secondary}"
                                                            BorderBrush="{DynamicResource Brush.Border}"
                                                            BorderThickness="1"
                                                            CornerRadius="2"
                                                            Padding="4,2"
                                                            Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding Type, Mode=OneWay}"
                                                                   FontSize="{DynamicResource Font.Caption}"
                                                                   FontFamily="{DynamicResource Font.Primary}"
                                                                   Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                                    </Border>
                                                    <!-- Status -->
                                                    <TextBlock Text="{Binding IpAddress, Mode=OneWay}"
                                                               FontSize="{DynamicResource Font.Caption}"
                                                               FontFamily="{DynamicResource Font.Primary}"
                                                               Foreground="{DynamicResource Brush.Text.Secondary}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </Canvas>
                    </Viewbox>
                </Grid>
            </Border>

            <!-- Log Panel -->
            <Border Grid.Column="1" Background="{DynamicResource Brush.Background.Secondary}" CornerRadius="6" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Olay Kayıtları (Logs)" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="LogPanel">
                            <TextBlock Text="[System] Simülasyon beklemede..." Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,5"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
