<Window x:Class="TCP.App.Views.LayerPropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Katman Özellikleri" Width="400"
        SizeToContent="Height" MaxHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Surface}"
        Foreground="{DynamicResource Brush.Text.Primary}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Özellikler" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16" Padding="0,0,8,0">
            <StackPanel>
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="İsim:" Margin="0,0,0,4"/>
                    <TextBox x:Name="NameTextBox" Width="300" HorizontalAlignment="Left"/>
                </StackPanel>

                <StackPanel x:Name="StationPanel" Margin="0,0,0,12" Visibility="Collapsed">
                    <TextBlock Text="IP Adresi:" Margin="0,8,0,4"/>
                    <TextBox x:Name="IpTextBox" Width="300" HorizontalAlignment="Left"/>
                    
                    <TextBlock Text="Port:" Margin="0,8,0,4"/>
                    <TextBox x:Name="PortTextBox" Width="300" HorizontalAlignment="Left"/>
                    
                    <TextBlock Text="MAC Adresi:" Margin="0,8,0,4"/>
                    <TextBox x:Name="MacTextBox" Width="300" HorizontalAlignment="Left"/>
                    
                    <TextBlock Text="Router Portu:" Margin="0,8,0,4"/>
                    <TextBox x:Name="RouterPortTextBox" Width="300" HorizontalAlignment="Left"/>
                </StackPanel>

                <StackPanel x:Name="ComponentPanel" Margin="0,0,0,12" Visibility="Collapsed">
                    <TextBlock Text="Mega Üzerindeki Pin:" Margin="0,8,0,4"/>
                    <TextBox x:Name="PinTextBox" Width="300" HorizontalAlignment="Left"/>
                </StackPanel>

                <StackPanel x:Name="TemplatePanel" Margin="0,0,0,12" Visibility="Collapsed">
                    <TextBlock Text="Açıklama:" Margin="0,8,0,4"/>
                    <TextBox x:Name="DescriptionTextBox" Width="300" HorizontalAlignment="Left" TextWrapping="Wrap" MinHeight="60"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Content="İptal" Appearance="Secondary" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <ui:Button Content="Kaydet" Appearance="Primary" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
