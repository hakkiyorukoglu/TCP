<UserControl x:Class="TCP.App.UI.Components.CodeEditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="600">
    <!--
        CodeEditorPanel.xaml - Reusable code editor panel component
        
        TCP-0.6.2: Electronics "Edit Code" Panel UI
        
        Purpose: Visually represent a code-editing area for future real editor integration.
        
        Structure:
        - Header: "Edit Board Code"
        - Editor area (TextBox with monospaced font)
        - Footer with Save button
        
        Rules:
        - Uses ONLY theme tokens
        - Card-style layout
        - No resizing side effects
        - UI-only (no compilation, no validation)
    -->
    <Grid>
        <Grid.RowDefinitions>
            <!-- Editor area -->
            <RowDefinition Height="*"/>
            <!-- Footer with Save button -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Code Editor TextBox -->
        <TextBox x:Name="CodeEditorTextBox"
                 Grid.Row="0"
                 FontFamily="Consolas"
                 FontSize="{DynamicResource Font.Body}"
                 Foreground="{DynamicResource Brush.Text.Primary}"
                 Background="{DynamicResource Brush.Surface}"
                 BorderBrush="{DynamicResource Brush.Border}"
                 BorderThickness="1"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Margin="0,0,0,12">
            <!-- Placeholder text (hardcoded as per requirement) -->
            <TextBox.Text>
                // Board code placeholder
// Logic will be editable in future versions
            </TextBox.Text>
        </TextBox>
        
        <!-- Footer with Save button -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <ui:Button Content="Save"
                       Appearance="Primary"
                       Width="80"
                       Height="30"
                       Cursor="Hand"
                       IsEnabled="False"
                       ToolTip="Save functionality will be available in later versions" />
        </StackPanel>
    </Grid>
</UserControl>
